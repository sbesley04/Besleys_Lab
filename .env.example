# Copy to .env and fill in. Never commit the real .env.

# --- Database -----------------------------------------------------------------
# Local dev: SQLite — a single file, no server needed.
DATABASE_URL="file:./dev.db"
# Vercel/production: switch prisma/schema.prisma provider to "postgresql" and
# point this at a hosted Postgres (Vercel Postgres / Neon / Supabase), e.g.:
# DATABASE_URL="postgresql://user:pass@host:5432/db?sslmode=require"

# --- NextAuth -------------------------------------------------------------------
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-string"
# Local dev URL; on Vercel set this to the deployed URL (or omit — Vercel sets it).
NEXTAUTH_URL="http://localhost:3000"

# --- Site ------------------------------------------------------------------------
# Absolute URL used for Open Graph tags, sitemap, and robots. Set to the
# production domain when deploying (e.g. https://besleyslab.vercel.app).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Seed credentials (prisma/seed.ts creates/updates the first admin) -----------
ADMIN_EMAIL="admin@besleyslab.dev"
ADMIN_PASSWORD="change-me-before-seeding"
ADMIN_NAME="Sam Besley"
ADMIN_USERNAME="admin"   # optional; defaults to "admin"
