{
  "name": "besleys-lab",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "vercel-build": "node scripts/prepare-vercel.mjs && prisma generate && prisma db push --skip-generate && tsx prisma/seed.ts && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test:engine": "node --experimental-strip-types app/games/tetris/engine.test.ts",
    "test:games": "node --experimental-strip-types app/games/_games.test.ts",
    "test:hunger": "node --experimental-strip-types app/games/hunger-games/engine.test.ts",
    "test": "npm run test:engine && npm run test:games && npm run test:hunger",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "create-user": "tsx scripts/create-user.ts",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.18.0",
    "bcryptjs": "^2.4.3",
    "marked": "^12.0.2",
    "next": "14.2.35",
    "next-auth": "^4.24.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.35",
    "prisma": "^5.18.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
